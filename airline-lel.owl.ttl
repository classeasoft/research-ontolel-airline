@prefix : <http://example.org/airline-lel#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/airline-lel#> .

<http://ontologies.mgis.unlp.org/airline-lel#> rdf:type owl:Ontology ;
                                                owl:imports <http://ontologies.mgis.unlp.org/airline-lel> ,
                                                            <http://ontologies.mgis.unlp.org/lel-metamodel/1.0> ;
                                                rdfs:comment "Domain ontology derived from an LEL for an airline: actors, objects, states and operational processes."@en ;
                                                rdfs:label "Airline LEL Domain Ontology (OWL2 DL)"@en .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/airline-lel#asociadoAItinerario
:asociadoAItinerario rdf:type owl:ObjectProperty ;
                     rdfs:domain :BilleteAereo ;
                     rdfs:range :Itinerario ;
                     rdfs:label "asociado a itinerario"@es .


###  http://example.org/airline-lel#asociadoAVuelo
:asociadoAVuelo rdf:type owl:ObjectProperty ;
                rdfs:domain :BilleteAereo ;
                rdfs:range :Vuelo ;
                rdfs:label "asociado a vuelo"@es .


###  http://example.org/airline-lel#checkInAsignaAsiento
:checkInAsignaAsiento rdf:type owl:ObjectProperty ;
                      rdfs:domain :CheckIn ;
                      rdfs:range :Asiento ;
                      rdfs:label "check-in asigna asiento"@es .


###  http://example.org/airline-lel#checkInEmiteTarjeta
:checkInEmiteTarjeta rdf:type owl:ObjectProperty ;
                     rdfs:domain :CheckIn ;
