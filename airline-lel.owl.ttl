###  http://example.org/airline-lel#NarrowBody
:NarrowBody rdf:type owl:Class ;
            rdfs:subClassOf :Aeronave ;
            owl:disjointWith :WideBody ;
            rdfs:label "Narrow-body"@en .


###  http://example.org/airline-lel#Pasajero
:Pasajero rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :tieneBillete ;
                            owl:someValuesFrom :BilleteAereo
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :tieneBillete ;
                            owl:allValuesFrom :BilleteAereo
                          ] ;
          rdfs:label "Pasajero"@es .


###  http://example.org/airline-lel#PasajeroFrecuente
:PasajeroFrecuente rdf:type owl:Class ;
                   rdfs:subClassOf :Pasajero ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :inscritoEn ;
                                     owl:someValuesFrom :ProgramaDeFidelidad
                                   ] ;
                   rdfs:label "Pasajero Frecuente"@es .


###  http://example.org/airline-lel#ProgramaDeFidelidad
:ProgramaDeFidelidad rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty :gestionadoPor ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass :CompaniaAerea
                                     ] ;
                     rdfs:label "Programa de Fidelidad"@es .


