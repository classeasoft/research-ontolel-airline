               rdfs:label "valida billete"@es .


#################################################################
#    Classes
#################################################################

###  http://example.org/airline-lel#Aeronave
:Aeronave rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :tieneEstadoAeronave ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :EstadoAeronave
                          ] ;
          rdfs:label "Aeronave"@es .


###  http://example.org/airline-lel#Aeropuerto
:Aeropuerto rdf:type owl:Class ;
            rdfs:label "Aeropuerto"@es .


###  http://example.org/airline-lel#Asiento
:Asiento rdf:type owl:Class ;
         rdfs:label "Asiento"@es .


###  http://example.org/airline-lel#AutoridadAeronautica
:AutoridadAeronautica rdf:type owl:Class ;
                      rdfs:label "Autoridad Aeronáutica"@es .


###  http://example.org/airline-lel#AutoridadAeroportuaria
:AutoridadAeroportuaria rdf:type owl:Class ;
                        rdfs:label "Autoridad Aeroportuaria"@es .


###  http://example.org/airline-lel#BilleteAereo
:BilleteAereo rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :asociadoAItinerario ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :Itinerario
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :tieneClaseTarifa ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :ClaseDeTarifa
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :tieneEstadoBillete ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :EstadoBillete
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :tieneTarifa ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :TarifaAerea
                              ] ;
              rdfs:label "Billete Aéreo"@es .


###  http://example.org/airline-lel#BilleteValido
:BilleteValido rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :BilleteAereo
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :tieneEstadoBillete ;
                                                            owl:someValuesFrom :EstadoBilleteEmitidoConfirmado
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:label "Billete Válido"@es .


###  http://example.org/airline-lel#Carga
:Carga rdf:type owl:Class ;
       rdfs:label "Carga"@es .


###  http://example.org/airline-lel#CheckIn
:CheckIn rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :checkInEmiteTarjeta ;
                           owl:someValuesFrom :TarjetaDeEmbarque
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :checkInParaVuelo ;
                           owl:someValuesFrom :Vuelo
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :checkInValidaBillete ;
                           owl:someValuesFrom :BilleteAereo
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :checkInValidaBillete ;
                           owl:allValuesFrom :BilleteValido
                         ] ;
         rdfs:label "Check-in"@es .


###  http://example.org/airline-lel#ClaseDeTarifa
:ClaseDeTarifa rdf:type owl:Class ;
               rdfs:label "Clase de Tarifa"@es .


###  http://example.org/airline-lel#ClaseTarifaEconomica
:ClaseTarifaEconomica rdf:type owl:Class ;
                      rdfs:subClassOf :ClaseDeTarifa ;
                      rdfs:label "Clase de Tarifa Económica (Y,B,M,H,Q,L,T,V,X,N)"@es .


###  http://example.org/airline-lel#ClaseTarifaEconomicaBasica
:ClaseTarifaEconomicaBasica rdf:type owl:Class ;
                            rdfs:subClassOf :ClaseDeTarifa ;
                            rdfs:label "Clase de Tarifa Económica Básica (E/O)"@es .


###  http://example.org/airline-lel#ClaseTarifaEconomicaPremium
:ClaseTarifaEconomicaPremium rdf:type owl:Class ;
                             rdfs:subClassOf :ClaseDeTarifa ;
                             rdfs:label "Clase de Tarifa Económica Premium (W/P)"@es .


###  http://example.org/airline-lel#ClaseTarifaEjecutiva
:ClaseTarifaEjecutiva rdf:type owl:Class ;
                      rdfs:subClassOf :ClaseDeTarifa ;
                      rdfs:label "Clase de Tarifa Ejecutiva (J,C,D,I,Z)"@es .


###  http://example.org/airline-lel#ClaseTarifaPrimeraClase
:ClaseTarifaPrimeraClase rdf:type owl:Class ;
                         rdfs:subClassOf :ClaseDeTarifa ;
                         rdfs:label "Clase de Tarifa Primera Clase (F/A)"@es .


###  http://example.org/airline-lel#ClaseTarifaPromocional
:ClaseTarifaPromocional rdf:type owl:Class ;
                        rdfs:subClassOf :ClaseDeTarifa ;
                        rdfs:label "Clase de Tarifa Promocional (R,S,G)"@es .


###  http://example.org/airline-lel#CompaniaAerea
:CompaniaAerea rdf:type owl:Class ;
               rdfs:label "Compañía Aérea"@es .


###  http://example.org/airline-lel#Embarque
:Embarque rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :embarqueActualizaManifiesto ;
                            owl:someValuesFrom :ManifiestoDeVuelo
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :embarqueParaVuelo ;
                            owl:someValuesFrom :Vuelo
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :embarqueUsaTarjeta ;
                            owl:someValuesFrom :TarjetaDeEmbarque
                          ] ;
          rdfs:label "Embarque"@es .


###  http://example.org/airline-lel#Equipaje
:Equipaje rdf:type owl:Class ;
          rdfs:label "Equipaje"@es .


