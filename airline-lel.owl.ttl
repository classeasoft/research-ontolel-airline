###  http://example.org/airline-lel#TarjetaDeEmbarque
:TarjetaDeEmbarque rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :tarjetaIndicaAsiento ;
                                     owl:someValuesFrom :Asiento
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :tarjetaParaPasajero ;
                                     owl:someValuesFrom :Pasajero
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :tarjetaParaVuelo ;
                                     owl:someValuesFrom :Vuelo
                                   ] ;
                   rdfs:label "Tarjeta de Embarque"@es .


###  http://example.org/airline-lel#Vuelo
:Vuelo rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :generaManifiesto ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :ManifiestoDeVuelo
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :llegaA ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Aeropuerto
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :saleDe ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Aeropuerto
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :tieneEstadoVuelo ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :EstadoVuelo
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :tieneItinerario ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Itinerario
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :usaAeronave ;
                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :Aeronave
                       ] ;
       rdfs:label "Vuelo"@es .


###  http://example.org/airline-lel#WideBody
:WideBody rdf:type owl:Class ;
          rdfs:subClassOf :Aeronave ;
          rdfs:label "Wide-body"@en .


